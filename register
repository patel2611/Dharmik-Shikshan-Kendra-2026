<!DOCTYPE html>
<html>
<head>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js"></script>

<style>
body {
  font-family:Poppins;
  background:#f5f7fb;
  display:flex;
  justify-content:center;
  padding:30px;
}

.card {
  background:white;
  padding:25px;
  border-radius:16px;
  width:350px;
}

input, select, button {
  width:100%;
  padding:10px;
  margin:8px 0;
}

button {
  background:#4f46e5;
  color:white;
  border:none;
}
</style>
</head>

<body>

<div class="card">
<h2>Student Registration</h2>

<input id="name" placeholder="Student Name">
<input id="mobile" placeholder="Mobile">
<select id="class">
  <option>Class 3-6</option>
  <option>Class 7-9</option>
  <option>Class 10+</option>
</select>

<input id="centre" placeholder="Centre">

<button onclick="saveStudent()">Save</button>
<p id="msg"></p>

</div>

<script>
const supabase = supabase.createClient("YOUR_URL","YOUR_ANON_KEY");

async function saveStudent() {

  const { data: user } = await supabase.auth.getUser();

  const { error } = await supabase.from('students').insert([{
    name: name.value,
    mobile: mobile.value,
    class: document.getElementById("class").value,
    centre: centre.value,
    created_by: user.user.id
  }]);

  if(error) msg.innerText = error.message;
  else msg.innerText = "Saved Successfully ✅";
}
</script>

</body>
</html>
